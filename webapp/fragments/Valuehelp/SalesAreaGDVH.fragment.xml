<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:core="sap.ui.core">
	<TableSelectDialog
	contentWidth="30%"
		noDataText="{i18n>salesAreaNoDataText}"
		title="{i18n>salesAreaTitle}"
		multiSelect="false" 
		search="handleVHSearch"
		rememberSelections="false"
		searchPlaceholder="{i18n>salesAreaPlaceHolder}"
		confirm="handleVHConfirm"
		cancel="handleVHCancel"
		showClearButton="true"
		 
		items="{
			path : 'PromoPlan>/SalesAreaSet' 
			 
		}">
		<ColumnListItem  >
			<cells>
				 
				<Text text="{PromoPlan>SaId}" />
				<Text text="{PromoPlan>SaName}" />
				 </cells>
		</ColumnListItem>
		<columns>
			<Column >
				<header>
					<Text text="{i18n>saId}" />
				</header>
			</Column>
			<Column minScreenWidth="Tablet" demandPopin="true">
				<header>
					<Text text="{i18n>salesArea}" />
				</header>
			</Column>
			 
		</columns>
	</TableSelectDialog>
</core:FragmentDefinition>