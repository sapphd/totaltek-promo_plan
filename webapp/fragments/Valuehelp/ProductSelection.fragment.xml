<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <TableSelectDialog
        contentWidth="30%"
        noDataText="{i18n>noDataText}"
        title="{i18n>selectProduct}"
        multiSelect="false"
        search="handleVHSearch"
        rememberSelections="false"
        searchPlaceholder="{i18n>searchPlaceholder}"
        confirm="handleVHConfirm"
        cancel="handleVHCancel"
        showClearButton="true"
        items="{
            path : 'appView>/ProductSelection'
        }">
        <columns>
         <Column visible="false">
                <header>
                    <Text text="{i18n>key}" />
                </header>
            </Column>
            <Column>
                <header>
                    <Text text="{i18n>ProductType}" />
                </header>
            </Column>

            
        </columns>
        <items>
            <ColumnListItem>
                <cells>
                    <Text text="{appView>key}" />
                    <Text text="{appView>name}" />
                                    

                </cells>
            </ColumnListItem>
        </items>
    </TableSelectDialog>
</core:FragmentDefinition>