<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:core="sap.ui.core">
	<TableSelectDialog
	contentWidth="30%"
		noDataText="{i18n>planTypeNoDataText}"
		title="{i18n>planTypeTitle}"
		multiSelect="false"
		search="handleVHSearch"
		rememberSelections="false"
		growing="true"
		growingThreshold="10"
		searchPlaceholder="{i18n>planTypeSrchPlaceHolder}"
		selectionChange="handleVHConfirm"
		confirm="handleVHConfirm"
		cancel="handleVHCancel"
		showClearButton="true"
		 
		items="{
			path : 'PromoPlan>/PromoPlanSet',
			parameters: {select: 'PlanType,Description'}
			 
		}">
		<ColumnListItem  >
			<cells>
				 
				<Text text="{PromoPlan>PlanType}" />
				<Text text="{PromoPlan>Description}" />
				 
				 </cells>
		</ColumnListItem>
		<columns>
			<Column  >
				<header>
					<Text text="{i18n>planType}" />
				</header>
			</Column>
			<Column minScreenWidth="Tablet" demandPopin="true"  >
				<header>
					<Text text="{i18n>description}" />
				</header>
			</Column>
			 
			 
			 
		</columns>
	</TableSelectDialog>
</core:FragmentDefinition>