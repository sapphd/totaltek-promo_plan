<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:core="sap.ui.core">
	<TableSelectDialog
	contentWidth="30%"
		noDataText="{i18n>subBrandNoDataText}"
		title="{i18n>subBrandTitle}"
		multiSelect="false"
		search="handleVHSearch"
		rememberSelections="false"
		searchPlaceholder="{i18n>subBrandSrchPlaceHolder}"
		confirm="handleVHConfirm"
		cancel="handleVHCancel"
		showClearButton="true"
		 
		items="{
			path : 'PromoPlan>/SubbrandSet',
			
			parameters: {select: 'Subrand,Subdesc'}
			 
		}">
		<ColumnListItem  >
			<cells>
				 
				<Text text="{PromoPlan>Subrand}" />
				<Text text="{PromoPlan>Subdesc}" />
				 </cells>
		</ColumnListItem>
		<columns>
			<Column >
				<header>
					<Text text="{i18n>subBrand}" />
				</header>
			</Column>
			<Column minScreenWidth="Tablet" demandPopin="true">
				<header>
					<Text text="{i18n>description}" />
				</header>
			</Column>
			 
		</columns>
	</TableSelectDialog>
</core:FragmentDefinition>