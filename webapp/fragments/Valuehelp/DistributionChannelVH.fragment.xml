<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:core="sap.ui.core">
	<TableSelectDialog
	contentWidth="30%"
		noDataText="{i18n>distChannelNoDataText}"
		title="{i18n>distChannelTitle}"
		 
		multiSelect="false"
		search="handleVHSearch"
		searchPlaceholder="{i18n>distChannelPlaceHolder}"
		confirm="handleVHConfirm"
		cancel="handleVHCancel"
		showClearButton="true"
		 
		items="{
			path : 'DistChan>/DistChSet' 
			 
		}">
		<ColumnListItem  >
			<cells>
				 
				<Text text="{DistChan>DistCh}" />
				<Text text="{DistChan>Description}" />
				 </cells>
		</ColumnListItem>
		<columns>
			<Column width="12em">
				<header>
					<Text text="{i18n>distChannel}" />
				</header>
			</Column>
			<Column minScreenWidth="Tablet" demandPopin="true">
				<header>
					<Text text="{i18n>description}" />
				</header>
			</Column>
			 
		</columns>
	</TableSelectDialog>
</core:FragmentDefinition>