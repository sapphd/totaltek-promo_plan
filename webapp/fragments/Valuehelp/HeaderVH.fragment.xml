
<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
    <TableSelectDialog
        contentWidth="30%"
        noDataText="{i18n>noDataText}"
        title="{i18n>title}"
        multiSelect="false"
        search="handleVHSearch"
        confirm="handleVHConfirm"
        cancel="handleVHCancel"
        showClearButton="true"
        items="{path: '{bindingPath}'}">
        <columns>
            <Column>
                <header><Text text="{i18n>column1}" /></header>
            </Column>
            <Column>
                <header><Text text="{i18n>column2}" /></header>
            </Column>
        </columns>
        <ColumnListItem>
            <cells>
                <Text text="{key}" />
                <Text text="{text}" />
            </cells>
        </ColumnListItem>
    </TableSelectDialog>
</core:FragmentDefinition>
