<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:core="sap.ui.core">
	<TableSelectDialog
		noDataText="{i18n>objectiveNoDataText}"
		contentWidth="30%"
		title="{i18n>objectiveTitle}"
		multiSelect="false"
		search="handleVHSearch"
		rememberSelections="false"
		searchPlaceholder="{i18n>objectivePlaceHolder}"
		confirm="handleVHConfirm"
		cancel="handleVHCancel"
		showClearButton="true"
		 
		items="{
			path : 'PromoPlan>/ObjectiveSet'
			 
		}">
		<ColumnListItem  >
			<cells>
				 
				<Text text="{PromoPlan>ObjectiveId}" />
				<Text text="{PromoPlan>description}" />
				 </cells>
		</ColumnListItem>
		<columns>
			<Column >
				<header>
					<Text text="{i18n>objective}" />
				</header>
			</Column>
			<Column minScreenWidth="Tablet" demandPopin="true">
				<header>
					<Text text="{i18n>description}" />
				</header>
			</Column>
			 
		</columns>
	</TableSelectDialog>
</core:FragmentDefinition>