<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:core="sap.ui.core">
	<TableSelectDialog
		noDataText="No Tactics Found"
		title="Select Tactics"
		multiSelect="false"
		contentWidth="30%"
		rememberSelections="false"
		search="handleVHSearch"
		searchPlaceholder="Search Tactics"
		confirm="handleVHConfirm"
		cancel="handleVHCancel"
		showClearButton="true"
		 
		items="{
			path : 'PromoPlan>/TacticsSet'
			 
		}">
		<ColumnListItem >
			<cells>
				 
				<Text text="{PromoPlan>TacticId}" />
				<Text text="{PromoPlan>description}" />
				 </cells>
		</ColumnListItem>
		<columns>
			<Column width="12em">
				<header>
					<Text text="Tactic Id" />
				</header>
			</Column>
			<Column minScreenWidth="Tablet" demandPopin="true">
				<header>
					<Text text="{i18n>description}" />
				</header>
			</Column>
			 
		</columns>
	</TableSelectDialog>
</core:FragmentDefinition>