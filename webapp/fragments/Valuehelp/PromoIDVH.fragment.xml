<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:core="sap.ui.core">
	<TableSelectDialog
	contentWidth="30%"
		noDataText="{i18n>planIdNoDataText}"
		title="{i18n>planIdTitle}"
		multiSelect="false"
		search="handleVHSearch"
		rememberSelections="false"
		searchPlaceholder="{i18n>planIdSrchPlaceHolder}"
		confirm="handleVHConfirm"
		cancel="handleVHCancel"
		showClearButton="true"
		 
		items="{
			path : '/Plan_HeaderSet',
			
			parameters: {select: 'PlanId,Description'}
			 
		}">
		<ColumnListItem  >
			<cells>
				 
				<Text text="{PlanId}" />
				<Text text="{Description}" />
				 </cells>
		</ColumnListItem>
		<columns>
			<Column >
				<header>
					<Text text="{i18n>PlanId}" />
				</header>
			</Column>
			<Column minScreenWidth="Tablet" demandPopin="true">
				<header>
					<Text text="{i18n>description}" />
				</header>
			</Column>
			 
		</columns>
	</TableSelectDialog>
</core:FragmentDefinition>