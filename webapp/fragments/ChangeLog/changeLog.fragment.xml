<core:FragmentDefinition xmlns="sap.m"
    xmlns:table="sap.ui.table"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns:f="sap.f"
    xmlns:layout="sap.ui.layout"
    xmlns:core="sap.ui.core"
    xmlns:smartTable="sap.ui.comp.smarttable">
    <layout:VerticalLayout id="changelogVerticalLayout" width="100%">
        <smartTable:SmartTable id="changeDocumentsTable" smartFilterId="smartFilterBar" 
        tableType="ResponsiveTable" editable="false" demandPopin="true" 
        enableAutoColumnWidth="true" showDetailsButton="true" 
        detailsButtonSetting="None,Low,Medium" entitySet="C_ChangeDocuments" 
        useVariantManagement="true" showVariantManagement="true" 
        useTablePersonalisation="true" header="{i18n>changeLog}" 
        noData="{i18n>changeLogNoData}" showRowCount="true" 
        enableAutoBinding="true" persistencyKey="SmartTableChangedoc_Variant"
        requestAtLeastFields="ChangeDocLanguageKey,CreatedByUser,CreationDate,CreationTime"
        beforeRebindTable=".onBeforeChangeDocRebindTable"
        >
        </smartTable:SmartTable>
    </layout:VerticalLayout>
</core:FragmentDefinition>


