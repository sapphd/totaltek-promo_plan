<core:FragmentDefinition
    xmlns:m="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:custom="com.kcc.promoplan.controls"
    xmlns:table="sap.ui.table"
    xmlns:core="sap.ui.core"
>
    <table:Table
        visible="{= ${appView>/isNewMode} || ${appView>/isEditMode} }"
        id="idPlanningOITable"
        rowMode="Fixed"
        rowsUpdated="onPlanningOITblRowUpdated"
        rows="{path:'PlanHeader>/To_Item/results',templateShareable: false}"
        selectionMode="MultiToggle"
        alternateRowColors="true"
        enableBusyIndicator="true"
    >
        <table:extension>
            <m:OverflowToolbar>
                <m:Title text="Planning" />
                <m:ToolbarSpacer />

                <m:Button
                    text="Add Spend"
                    type="Emphasized"
                    icon="sap-icon://add"
                    press="onPlanningOIAddColumn"
                />
                <m:Button
                    text="Remove Spend"
                    type="Negative"
                    icon="sap-icon://less"
                    press="onPlanningOIRemoveColumns"
                />

                <m:Button
                    text="Add"
                    type="Emphasized"
                    icon="sap-icon://add"
                    press="onPlanningOIAddRow"
                />
                <m:Button
                    text="Delete"
                    type="Negative"
                    icon="sap-icon://delete"
                    press="onPlanningOIDeleteRow"
                />
            </m:OverflowToolbar>
        </table:extension>

        <!-- Columns -->
        <table:columns>
            <table:Column
                width="9rem"
                visible="{= ${appView>/ProductHierarchy}}"
            >
                <m:Label text="Product Hierarchy" />
                <table:template>
                    <custom:ProductHierarchy
                        value="{PlanHeader>Prodh}"
                        saId="{PlanHeader>/Sa_Id}"
                        editable="{= !${PlanHeader>IsSummary}}"
                        valueLiveUpdate="true"
                        serviceUrl="/sap/opu/odata/sap/ZPRTP4_PROD_HIERARCHY_F4_SRV/"
                        valueHelpEnabled="true"
                        valueSelected="onProductValueSelected"
                    />
                </table:template>
            </table:Column>
            <table:Column
                width="28rem"
                visible="{= ${appView>/Product}}"
            >
                <m:Label text="Product" />

                <table:template>
                    <m:MultiInput
                        showValueHelp="true"
                        editable="{= !${PlanHeader>IsSummary}}"
                       
                        tokenUpdate="onOIVHTokenUpdate"
                        valueHelpRequest="onOIValueHelp"
                        suggestionItems="{ 
				path: 'FilteredSellingSKU>/SellingSKUSet',
                templateShareable: false
                 

			}"
                    >
                        <core:Item
                            key="{FilteredSellingSKU>Matnr}"
                            text="{FilteredSellingSKU>matnr_desc}"
                        />
                        <m:customData>
                            <core:CustomData
                                key="valuehelp"
                                value="SellingSKU"
                            />
                        </m:customData>
                    </m:MultiInput>
                </table:template>
            </table:Column>
            <table:Column
                width="17rem"
                visible="{= ${appView>/Brand}||${appView>/SubBrand}}"
            >
                <m:Label text="Brand" />
                <table:template>
                    <m:MultiInput
                        showValueHelp="true"
                        editable="{= !${PlanHeader>IsSummary}}"
                        tokenUpdate="onOIVHTokenUpdate"
                        valueHelpRequest="onOIValueHelp"
                        suggestionItems="{
				path: 'PromoPlan>/BrandSet' 
			}"
                        
                    >
                        <core:ListItem
                            key="{PromoPlan>Domvalue}"
                            text="{PromoPlan>Description}"
                               additionalText="{PromoPlan>Domvalue}"
                        />
                        <m:customData>
                            <core:CustomData
                                key="valuehelp"
                                value="Brand"
                            />
                        </m:customData>
                    </m:MultiInput>
                </table:template>
            </table:Column>
            <table:Column
                width="17rem"
                visible="{= ${appView>/SubBrand}}"
            >
                <m:Label text="Sub-brand" />

                <table:template>
                    <m:MultiInput
                        showValueHelp="true"
                        editable="{= !${PlanHeader>IsSummary}}"
                        tokenUpdate="onOIVHTokenUpdate"
                        valueHelpRequest="onOIValueHelp"
                        suggestionItems="{
				path: 'PromoPlan>/SubbrandSet' 
			}"
                        
                    >
                        <core:ListItem
                            key="{PromoPlan>Subrand}"
                            text="{PromoPlan>Subdesc}"
                             additionalText="{PromoPlan>Subrand}"
                        />

                        <m:customData>
                            <core:CustomData
                                key="valuehelp"
                                value="SubBrand"
                            />
                        </m:customData>
                    </m:MultiInput>
                </table:template>
            </table:Column>

            <table:Column width="7rem" hAlign="End">
                <m:Label text=" Total Volume" />
                <table:template>
                    <m:Text text="{PlanHeader>VolumePlanned}"   textAlign="End"/>
                </table:template>
            </table:Column>

            <table:Column width="6rem">
                <m:Label text="Baseline" />
                <table:template>
                    <m:Input
                        editable="{= !${PlanHeader>IsSummary}}"
                        type="Number"
                          textAlign="End"
                        value="{PlanHeader>Baseline}"
                        valueLiveUpdate="true"
                        change="onBaselineChange"
                    />
                </table:template>
            </table:Column>
            <table:Column width="7rem">
                <m:Label text="Uplift" />
                <table:template>
                    <m:Input
                        editable="{= !${PlanHeader>IsSummary}}"
                        value="{PlanHeader>Uplift}"
                        type="Number"
                          textAlign="End"
                        valueLiveUpdate="true"
                        change="onUpliftChange"
                    />
                </table:template>
            </table:Column>

            <table:Column
                width="5rem"
                hAlign="End"
            >
                <m:Label text="List Price" />
                <table:template>
                    <m:Input
                        editable="{= !${PlanHeader>IsSummary}}"
                        textAlign="End"
                        value="{PlanHeader>ListPrice}"
                        valueLiveUpdate="true"
                        liveChange="onListPriceOrVolumeChange"
                    />
                </table:template>
            </table:Column>

            <table:Column
                width="7rem"
                hAlign="End"
            >
                <m:Label text="EDLP Discount" />
                <table:template>
                    <m:Text text="{PlanHeader>DiscountEdlp}"   textAlign="End"/>
                </table:template>
            </table:Column>

            <table:Column
                width="9rem"
                hAlign="End"
            >
                <m:Label text="Edlp" />
                <table:template>
                    <m:Input
                        editable="{= !${PlanHeader>IsSummary}}"
                        textAlign="End"
                        value="{PlanHeader>NetCost}"
                        valueLiveUpdate="true"
                        liveChange="onSalesCostChange"
                    />
                </table:template>
            </table:Column>

            <table:Column
                width="9rem"
                hAlign="End"
            >
                <m:Label text="Regular Price" />
                <table:template>
                    <m:Input
                        editable="{= !${PlanHeader>IsSummary}}"
                        value="{PlanHeader>RegularPrice}"
                        valueLiveUpdate="true"
                        textAlign="End"
                        liveChange="updateSummaryRow"
                    />
                </table:template>
            </table:Column>

            <table:Column width="9rem">
                <m:Label text="Shelf Price" />
                <table:template>
                    <m:Input
                        editable="{= !${PlanHeader>IsSummary}}"
                        value="{PlanHeader>RetailPrice}"
                        textAlign="End"
                        valueLiveUpdate="true"
                        liveChange="updateSummaryRow"
                    />
                </table:template>
            </table:Column>

            <table:Column width="10rem">
                <m:Label text="Spend Type1" />
                <table:template>
                    <m:VBox>
                        <m:MultiInput
                            showValueHelp="true"
                            visible="{= ${PlanHeader>IsSummary}}"
                            valueHelpRequest="onOISpendValueHelp"
                            suggestionItems="{
				path: 'PromoPlan>/SpendSet' 
			}"
                            width="150px"
                        >
                            <core:Item
                                key="{PromoPlan>SpendType}"
                                text="{PromoPlan>Description}"
                            />
                            <m:customData>
                                <core:CustomData
                                    key="valuehelp"
                                    value="SpendType1"
                                />
                            </m:customData>
                        </m:MultiInput>
                        <m:Text
                            visible="{= !${PlanHeader>IsSummary}}"
                            text="{PlanHeader>SpendType1Desc}"
                        />
                    </m:VBox>
                </table:template>
            </table:Column>
            <table:Column width="8rem">
                <m:Label text="Tactic1" />
                <table:template>
                    <m:Text text="{PlanHeader>TacticDesc1}" />
                </table:template>
            </table:Column>

            <table:Column width="8rem">
                <m:Label text="Spend Method1" />
                <table:template>
                    <m:Text text="{PlanHeader>SpendMethod1}" />
                </table:template>
            </table:Column>

            <table:Column
                width="7rem"
                visible="{= ${appView>/Discount1}}"
            >
                <m:Label text="Discount1" />
                <table:template>
                    <m:Input
                        valueLiveUpdate="true"
                        textAlign="End"
                        value="{PlanHeader>Discount1}"
                        liveChange="onDiscountChange"
                    />
                </table:template>
            </table:Column>
            <table:Column
                width="9rem"
                visible="{= ${appView>/DiscountAmt1}}"
            >
                <m:Label text="Discount Amount1" />
                <table:template>
                    <m:Input
                        editable="{= !(${PlanHeader>IsSummary} &amp;&amp; ${PlanHeader>SpendMethod1} === 'F' &amp;&amp; ${PlanHeader>SpendAlloc1} === '') }"
                        liveChange="onDiscountAmountChange"
                        valueLiveUpdate="true"
                        textAlign="End"
                        value="{PlanHeader>DiscountAmt1}"
                    />
                </table:template>
            </table:Column>

            <table:Column
                width="10rem"
                visible="{= ${appView>/SpendType2}}"
