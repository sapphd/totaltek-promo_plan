            >
                <m:Label text="Discount3" />
                <table:template>
                    <m:Input
                        liveChange="onDiscountChange"
                        valueLiveUpdate="true"
                        textAlign="End"
                        value="{PlanHeader>Discount3}"
                    />
                </table:template>
            </table:Column>
            <table:Column
                width="9rem"
                visible="{= ${appView>/DiscountAmt3}}"
            >
                <m:Label text="Discount Amount3" />
                <table:template>
                    <m:Input
                        editable="{= !(${PlanHeader>IsSummary} &amp;&amp; ${PlanHeader>SpendMethod3} === 'F' &amp;&amp; ${PlanHeader>SpendAlloc3} === '') }"
                        liveChange="onDiscountAmountChange"
                        textAlign="End"
                        valueLiveUpdate="true"
                        value="{PlanHeader>DiscountAmt3}"
                    />
                </table:template>
            </table:Column>

            <table:Column
                width="10rem"
                visible="{= ${appView>/SpendType4}}"
            >
                <m:Label text="Spend Type4" />
                <table:template>
                    <m:VBox>
                        <m:MultiInput
                            visible="{= ${PlanHeader>IsSummary}}"
                            showValueHelp="true"
                            valueHelpRequest="onOISpendValueHelp"
                            suggestionItems="{
				path: 'PromoPlan>/SpendSet' 
