                        valueLiveUpdate="true"
                    />
                </table:template>
            </table:Column>

            <table:Column width="7rem">
                <m:Label text="NIV" />
                <table:template>
                    <m:Input
                        editable="false"
                        value="{PlanHeader>Niv}"
                        type="Number"
                          textAlign="End"
                        valueLiveUpdate="true"
                    />
                </table:template>
            </table:Column>

            <table:Column width="7rem">
                <m:Label text="LTA Deffered" />
