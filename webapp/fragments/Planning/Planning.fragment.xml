            </table:Column>

            <table:Column width="10rem" hAlign="End">
                <m:Label text="Total Sales" />
                <table:template>
                    <m:Text text="{PlanHeader>SalesPlanned}"   textAlign="End"/>
                </table:template>
            </table:Column>

            <table:Column width="7rem">
                <m:Label text="Total OI Cost" />
                <table:template>
                    <m:Input
                        editable="false"
                        value="{PlanHeader>SpendPlannedOi}"
                        type="Number"
